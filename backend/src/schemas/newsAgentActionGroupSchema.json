{
  "openapi": "3.0.0",
  "info": {
    "title": "News Search Action Group API",
    "version": "1.0.0",
    "description": "API for searching news from multiple sources including Google News and custom RSS feeds"
  },
  "paths": {
    "/searchGoogleNews": {
      "post": {
        "summary": "Search Google News by single keyword",
        "description": "Searches Google News RSS feed for articles matching the given keyword. Use this for simple single-keyword searches.",
        "operationId": "searchGoogleNews",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keyword": {
                    "type": "string",
                    "description": "The search keyword or phrase to find news articles about"
                  }
                },
                "required": ["keyword"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with news items from Google News",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/searchGoogleNewsAdvanced": {
      "post": {
        "summary": "Search Google News with multiple keywords and date filtering",
        "description": "Searches Google News for multiple keywords simultaneously with optional date range filtering. Use this when user specifies multiple search terms or wants news from a specific time period (e.g., 'last 7 days', 'past 10 days'). Results are deduplicated and sorted by date.",
        "operationId": "searchGoogleNewsAdvanced",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keywords": {
                    "type": "array",
                    "description": "Array of search keywords or phrases. Each keyword will be searched separately and results will be combined and deduplicated.",
                    "items": {
                      "type": "string"
                    },
                    "example": ["油气 数字化", "油气 信息化", "OSDU"]
                  },
                  "daysBack": {
                    "type": "integer",
                    "description": "Optional number of days to look back. For example, 7 means last 7 days, 10 means last 10 days. If not specified, searches all available news.",
                    "example": 10
                  }
                },
                "required": ["keywords"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with deduplicated news items from all keywords",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fetchRssFeed": {
      "post": {
        "summary": "Fetch news from a specific RSS feed URL",
        "description": "Fetches and parses news from a custom RSS feed URL. Use this when you have a specific news source URL to fetch from.",
        "operationId": "fetchRssFeed",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "The RSS feed URL to fetch news from (e.g., https://feeds.bbci.co.uk/news/rss.xml)"
                  }
                },
                "required": ["url"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with news items from the RSS feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/searchMultipleSources": {
      "post": {
        "summary": "Search news from multiple sources simultaneously",
        "description": "Searches Google News and optionally multiple custom RSS feeds, then combines and sorts results. Use this when you want comprehensive coverage from multiple sources.",
        "operationId": "searchMultipleSources",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keyword": {
                    "type": "string",
                    "description": "The search keyword or phrase"
                  },
                  "rssFeedUrls": {
                    "type": "array",
                    "description": "Optional array of RSS feed URLs to search in addition to Google News",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": ["keyword"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with combined news items from all sources",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "NewsResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the search was successful"
          },
          "source": {
            "type": "string",
            "description": "The source of the news (e.g., 'Google News', RSS URL)"
          },
          "message": {
            "type": "string",
            "description": "Status message"
          },
          "items": {
            "type": "array",
            "description": "Array of news items found",
            "items": {
              "$ref": "#/components/schemas/NewsItem"
            }
          }
        }
      },
      "NewsItem": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "News article title"
          },
          "link": {
            "type": "string",
            "description": "URL to the full article"
          },
          "description": {
            "type": "string",
            "description": "Brief description or excerpt of the article"
          },
          "pubDate": {
            "type": "string",
            "description": "Publication date in RFC 822 format"
          },
          "source": {
            "type": "string",
            "description": "News source name or publisher"
          }
        }
      }
    }
  }
}
